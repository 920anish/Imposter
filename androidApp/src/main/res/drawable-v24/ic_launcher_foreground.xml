<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_launcher_foreground.xml — redesigned
    viewport: 360 × 360  (standard Android adaptive icon foreground)
    safe zone: 66px inset each side  →  drawable area ~228 × 228
    mask centred at (180, 185); eyes sit squarely inside the mask body
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="360"
    android:viewportHeight="360">
  <group android:scaleX="0.8"
      android:scaleY="0.8"
      android:translateX="36"
      android:translateY="36">

      <!-- ═══════════════════════════════════════════
           1. DROP SHADOW  (offset 0,6  blur ~10)
           Rendered as a slightly expanded, soft-dark
           copy shifted down so the mask appears to
           float above the background.
      ═══════════════════════════════════════════ -->
      <path
          android:fillColor="#0A0C1C"
          android:fillAlpha="0.55"
          android:translateY="7"
          android:pathData="
              M 180 110
              C 180 110, 140 104, 105 118
              C  75 130,  62 158,  62 190
              C  62 228,  78 252,  104 252
              C  128 252, 144 236,  156 214
              C  166 196, 172 184,  180 181
              C  188 184, 194 196,  204 214
              C  216 236, 232 252,  256 252
              C  282 252, 298 228,  298 190
              C  298 158, 285 130,  255 118
              C  220 104, 180 110, 180 110
              Z" />

      <!-- ═══════════════════════════════════════════
           2. MASK BODY — rich blue-slate gradient
           Taller & more centred; cheek wings curve
           down naturally; top arch is pronounced.
      ═══════════════════════════════════════════ -->
      <path
          android:pathData="
              M 180 110
              C 180 110, 140 104, 105 118
              C  75 130,  62 158,  62 190
              C  62 228,  78 252,  104 252
              C  128 252, 144 236,  156 214
              C  166 196, 172 184,  180 181
              C  188 184, 194 196,  204 214
              C  216 236, 232 252,  256 252
              C  282 252, 298 228,  298 190
              C  298 158, 285 130,  255 118
              C  220 104, 180 110, 180 110
              Z">
          <aapt:attr name="android:fillColor">
              <gradient
                  android:type="linear"
                  android:startX="180"
                  android:startY="104"
                  android:endX="180"
                  android:endY="252"
                  android:startColor="#566BB8"
                  android:endColor="#1C2A5C"/>
          </aapt:attr>
      </path>

      <!-- ═══════════════════════════════════════════
           3. TOP SHEEN HIGHLIGHT
           Simulates a gloss coat on the upper portion,
           giving a premium curved-surface look.
      ═══════════════════════════════════════════ -->
      <path
          android:pathData="
              M 180 110
              C 180 110, 140 104, 105 118
              C  75 130,  62 158,  62 172
              C  82 148, 118 136, 180 134
              C  242 136, 278 148, 298 172
              C  298 158, 285 130,  255 118
              C  220 104, 180 110, 180 110
              Z">
          <aapt:attr name="android:fillColor">
              <gradient
                  android:type="linear"
                  android:startX="180"
                  android:startY="104"
                  android:endX="180"
                  android:endY="172"
                  android:startColor="#8EA4DC"
                  android:endColor="#00000000"/>
          </aapt:attr>
      </path>

      <!-- ═══════════════════════════════════════════
           4. OUTER BORDER STROKE
           Thin, slightly lighter than the body to
           define the mask edge cleanly at small sizes.
      ═══════════════════════════════════════════ -->
      <path
          android:fillColor="#00000000"
          android:strokeColor="#5068A8"
          android:strokeWidth="1.8"
          android:strokeLineCap="round"
          android:strokeLineJoin="round"
          android:pathData="
              M 180 110
              C 180 110, 140 104, 105 118
              C  75 130,  62 158,  62 190
              C  62 228,  78 252,  104 252
              C  128 252, 144 236,  156 214
              C  166 196, 172 184,  180 181
              C  188 184, 194 196,  204 214
              C  216 236, 232 252,  256 252
              C  282 252, 298 228,  298 190
              C  298 158, 285 130,  255 118
              C  220 104, 180 110, 180 110
              Z" />

      <!-- ═══════════════════════════════════════════
           5. LEFT EYE CUTOUT
           Centre: (128, 168)  — sits inside the mask,
           vertically centred in the upper mask body.
           rx=34 ry=23 → slightly wider than tall,
           realistic for a goggle/visor eye shape.
      ═══════════════════════════════════════════ -->
      <!-- Eye socket depth shadow ring -->
      <path
          android:fillColor="#00000000"
          android:strokeColor="#0A0F28"
          android:strokeWidth="4"
          android:pathData="M 128 168 m -34 0 a 34 23 0 1 0 68 0 a 34 23 0 1 0 -68 0" />
      <!-- Eye socket fill -->
      <path
          android:fillColor="#06070F"
          android:pathData="M 128 168 m -34 0 a 34 23 0 1 0 68 0 a 34 23 0 1 0 -68 0" />
      <!-- Eye rim: inner glow ring -->
      <path
          android:fillColor="#00000000"
          android:strokeColor="#283C78"
          android:strokeWidth="1.2"
          android:pathData="M 128 168 m -34 0 a 34 23 0 1 0 68 0 a 34 23 0 1 0 -68 0" />
      <!-- Subtle lens reflection in upper-left of eye -->
      <path
          android:fillColor="#1A2860"
          android:fillAlpha="0.55"
          android:pathData="M 118 160 C 120 156, 128 155, 132 158 C 130 164, 122 164, 118 160 Z" />

      <!-- ═══════════════════════════════════════════
           6. RIGHT EYE CUTOUT
           Centre: (232, 168) — mirrors the left eye.
      ═══════════════════════════════════════════ -->
      <path
          android:fillColor="#00000000"
          android:strokeColor="#0A0F28"
          android:strokeWidth="4"
          android:pathData="M 232 168 m -34 0 a 34 23 0 1 0 68 0 a 34 23 0 1 0 -68 0" />
      <path
          android:fillColor="#06070F"
          android:pathData="M 232 168 m -34 0 a 34 23 0 1 0 68 0 a 34 23 0 1 0 -68 0" />
      <path
          android:fillColor="#00000000"
          android:strokeColor="#283C78"
          android:strokeWidth="1.2"
          android:pathData="M 232 168 m -34 0 a 34 23 0 1 0 68 0 a 34 23 0 1 0 -68 0" />
      <path
          android:fillColor="#1A2860"
          android:fillAlpha="0.55"
          android:pathData="M 222 160 C 224 156, 232 155, 236 158 C 234 164, 226 164, 222 160 Z" />

      <!-- ═══════════════════════════════════════════
           7. NOSE BRIDGE  — subtle centre seam
           A very soft V connecting the two eye wells,
           reinforcing the symmetry and tactile depth.
      ═══════════════════════════════════════════ -->
      <path
          android:fillColor="#00000000"
          android:strokeColor="#3A508A"
          android:strokeWidth="1.0"
          android:strokeLineCap="round"
          android:pathData="M 162 173 Q 180 182, 198 173" />

  </group>
</vector>
